# Copy this file to .env.local and fill in real values. Never commit .env.local.

# ============================================
# Required
# ============================================

# Supabase — get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — used for AI payment-receipt validation
ANTHROPIC_API_KEY=sk-ant-...

# football-data.org — used for match data + live scores
FOOTBALL_DATA_API_KEY=your-football-data-api-key

# Used to authorize external crons (cron-job.org, Vercel cron) that hit
# /api/matches/live-sync, /api/matches/sync, /api/polymarket/sync.
# Generate with: openssl rand -base64 32
CRON_SECRET=generate-a-strong-random-string

# Admin identity
ADMIN_EMAIL=admin@example.com
ADMIN_DISPLAY_NAME=Admin Name

# Payment details — these are just examples, replace with real values or payment details.
PAYMENT_BIZUM=674085579
PAYMENT_TRANSFERENCIA=ES0000000000000000000000

# ============================================
# Optional
# ============================================

# Sentry — error monitoring. Without these, Sentry is disabled at build/runtime.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Upstash Redis — rate limiting. Without these, rate limits become no-ops.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
